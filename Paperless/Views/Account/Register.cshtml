@model Paperless.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація співробітника";
}

<div class="row justify-content-center my-4 my-lg-5">
    <div class="col-lg-9 col-xl-8 reveal">
        <div class="card auth-card border-0">
            <div class="row g-0">
                <div class="col-md-5 d-none d-md-block">
                    <div class="auth-aside h-100 d-flex flex-column justify-content-center">
                        <div class="brand mb-4">Paperless</div>
                        <p class="fw-bold fs-5 mb-4">Створіть обліковий запис співробітника.</p>
                        <div class="feature"><i class="bi bi-person-plus"></i><span>Базова роль «Співробітник»</span></div>
                        <div class="feature"><i class="bi bi-cloud-upload"></i><span>Завантаження документів</span></div>
                        <div class="feature"><i class="bi bi-send"></i><span>Надсилання на розгляд</span></div>
                    </div>
                </div>
                <div class="col-md-7">
                    <div class="card-body p-4 p-lg-5">
                        <h1 class="h3 mb-1">Реєстрація</h1>
                        <p class="text-muted mb-4">Заповніть дані, щоб створити акаунт.</p>

                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LastName" class="form-label fw-bold"></label>
                                    <input asp-for="LastName" class="form-control" />
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="FirstName" class="form-label fw-bold"></label>
                                    <input asp-for="FirstName" class="form-control" />
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-bold"></label>
                                <input asp-for="Email" class="form-control" placeholder="example@organization.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Position" class="form-label fw-bold"></label>
                                    <input asp-for="Position" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Department" class="form-label fw-bold"></label>
                                    <input asp-for="Department" class="form-control" />
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Password" class="form-label fw-bold"></label>
                                    <input asp-for="Password" class="form-control" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                                    <input asp-for="ConfirmPassword" class="form-control" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-person-check me-1"></i> Створити акаунт
                                </button>
                            </div>
                        </form>

                        <div class="mt-4 text-center text-muted">
                            Вже зареєстровані?
                            <a asp-action="Login" class="fw-bold">Увійти</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
