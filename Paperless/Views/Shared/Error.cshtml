@model ErrorViewModel
@{
    ViewData["Title"] = "Помилка";
}

<div class="row justify-content-center my-5">
    <div class="col-lg-7 reveal">
        <div class="card text-center">
            <div class="card-body p-5">
                <div class="avatar-xl-fallback mx-auto mb-4" style="background: linear-gradient(135deg, var(--rejected), #E0655B);">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h1 class="text-danger mb-2">Сталася помилка</h1>
                <p class="text-secondary fs-5 mb-4">Під час обробки вашого запиту виникла помилка.</p>

                @if (Model.ShowRequestId)
                {
                    <p class="mb-4">
                        <span class="text-muted">Код запиту:</span>
                        <code class="ms-1">@Model.RequestId</code>
                    </p>
                }

                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                    <i class="bi bi-house me-1"></i> На головну
                </a>

                <hr class="divider-soft my-4">

                <div class="text-start text-muted small">
                    <p class="fw-bold mb-1">Режим розробки</p>
                    <p class="mb-0">
                        Перемикання у середовище <strong>Development</strong> відобразить детальнішу інформацію про помилку.
                        Це середовище не слід вмикати для розгорнутих застосунків, оскільки воно може показувати
                        чутливу інформацію кінцевим користувачам.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
