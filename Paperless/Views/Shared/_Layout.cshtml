@using Microsoft.AspNetCore.Identity
@using Paperless.Models
@inject UserManager<ApplicationUser> UserManager
@{
    ApplicationUser? navUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
    string navInitials = navUser != null
        ? $"{(navUser.LastName.Length > 0 ? navUser.LastName[0] : ' ')}{(navUser.FirstName.Length > 0 ? navUser.FirstName[0] : ' ')}".Trim()
        : "";
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Paperless</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Unbounded:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Paperless.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Paperless</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-grid-1x2 me-1"></i> Головна
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-area="" asp-controller="Document" asp-action="Index">
                                    <i class="bi bi-file-earmark-text me-1"></i> Документи
                                </a>
                            </li>
                            @if (User.IsInRole("Адміністратор"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-danger fw-bold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-shield-lock me-1"></i> Адміністрування
                                    </a>
                                    <ul class="dropdown-menu shadow-sm border-0" aria-labelledby="adminDropdown">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Index">
                                                <i class="bi bi-people me-2"></i> Управління ролями
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="AuditLog">
                                                <i class="bi bi-clock-history me-2"></i> Журнал аудиту
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Конфіденційність</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center me-2">
                                <a asp-controller="Profile" asp-action="Index" class="nav-link d-flex align-items-center gap-2" title="Мій профіль">
                                    @if (navUser != null && !string.IsNullOrEmpty(navUser.AvatarPath))
                                    {
                                        <img src="@navUser.AvatarPath" class="nav-avatar" alt="avatar" />
                                    }
                                    else
                                    {
                                        <span class="nav-avatar-fallback">@navInitials</span>
                                    }
                                    <span class="fw-bold text-dark d-none d-md-inline">@(navUser?.FirstName ?? User.Identity.Name)</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-box-arrow-right me-1"></i> Вийти
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Реєстрація</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-3" asp-controller="Account" asp-action="Login">Увійти</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>&copy; @DateTime.Now.Year — Paperless · Електронний документообіг</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Конфіденційність</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
