@model IEnumerable<Paperless.Models.Document>
@using Paperless.Models.Enums
@using Microsoft.AspNetCore.Identity
@inject UserManager<Paperless.Models.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Реєстр документів";
    var currentUserId = UserManager.GetUserId(User);

    var statuses = Html.GetEnumSelectList<DocumentStatus>().ToList();
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
    foreach (var item in statuses)
    {
        if (item.Value == currentFilter)
        {
            item.Selected = true;
        }
    }
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="page-head d-flex justify-content-between align-items-end flex-wrap gap-3">
    <div>
        <div class="eyebrow">Документообіг</div>
        <h1>Реєстр документів</h1>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Створити документ
    </a>
</div>

<div class="card mb-4 reveal">
    <div class="card-body p-3">
        <form asp-action="Index" method="get">
            <div class="row g-2 align-items-center">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentSearch"]"
                               class="form-control" placeholder="Пошук за назвою або описом…" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text">Статус</span>
                        <select name="statusFilter" asp-items="statuses" class="form-select">
                            <option value="">Усі статуси</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-funnel me-1"></i> Шукати</button>
                    @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()) || ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary" title="Скинути фільтри">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card reveal mb-5">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Назва документа</th>
                        <th>Автор</th>
                        <th>Дата створення</th>
                        <th>Статус</th>
                        <th class="text-center pe-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-folder-x"></i>
                                    Документів поки що немає в системі.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    @item.Title
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <small class="text-muted d-block fw-normal text-truncate" style="max-width: 320px;">
                                            @item.Description
                                        </small>
                                    }
                                </td>
                                <td>
                                    <span class="fw-bold">@item.Author?.FullName</span>
                                    <small class="text-muted d-block" style="font-size: 0.8rem;">@item.Author?.Position</small>
                                </td>
                                <td class="text-muted">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case DocumentStatus.Draft:
                                            <span class="badge bg-secondary"><i class="bi bi-pencil"></i> Чернетка</span>
                                            break;
                                        case DocumentStatus.PendingReview:
                                            <span class="badge bg-warning"><i class="bi bi-hourglass-split"></i> На розгляді</span>
                                            break;
                                        case DocumentStatus.Approved:
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Затверджено</span>
                                            break;
                                        case DocumentStatus.Rejected:
                                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Відхилено</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center pe-4 align-middle" style="min-width: 170px;">
                                    <div class="d-flex flex-column gap-2">
                                        @if (!string.IsNullOrEmpty(item.FilePath))
                                        {
                                            <a asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary w-100" title="Завантажити @item.OriginalFileName">
                                                <i class="bi bi-download me-1"></i> Завантажити
                                            </a>
                                            @if (!string.IsNullOrEmpty(item.OriginalFileName))
                                            {
                                                <small class="text-muted text-truncate" style="max-width: 160px;" title="@item.OriginalFileName">
                                                    <i class="bi bi-paperclip"></i> @item.OriginalFileName
                                                </small>
                                            }
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary w-100" disabled><i class="bi bi-file-earmark"></i> Без файлу</button>
                                        }

                                        <hr class="divider-soft w-100 my-0" />

                                        @if (item.AuthorId == currentUserId && item.Status == DocumentStatus.Draft)
                                        {
                                            <form asp-action="ChangeStatus" method="post" class="w-100">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="newStatus" value="@DocumentStatus.PendingReview" />
                                                <button type="submit" class="btn btn-sm btn-warning w-100"><i class="bi bi-send me-1"></i> На розгляд</button>
                                            </form>
                                        }

                                        @if ((User.IsInRole("Адміністратор") || User.IsInRole("Менеджер")) && item.Status == DocumentStatus.PendingReview)
                                        {
                                            <form asp-action="ChangeStatus" method="post" class="w-100">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="newStatus" value="@DocumentStatus.Approved" />
                                                <button type="submit" class="btn btn-sm btn-success w-100"><i class="bi bi-check-lg me-1"></i> Затвердити</button>
                                            </form>
                                            <form asp-action="ChangeStatus" method="post" class="w-100">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="newStatus" value="@DocumentStatus.Rejected" />
                                                <button type="submit" class="btn btn-sm btn-danger w-100"><i class="bi bi-x-lg me-1"></i> Відхилити</button>
                                            </form>
                                        }

                                        @if (item.AuthorId == currentUserId || User.IsInRole("Адміністратор"))
                                        {
                                            <div class="btn-group w-100">
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Ред.</a>
                                                <button type="button" class="btn btn-sm btn-outline-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteModal"
                                                        data-doc-id="@item.Id"
                                                        data-doc-title="@item.Title">
                                                    <i class="bi bi-trash"></i> Вид.
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header bg-danger text-white border-bottom-0">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Підтвердження видалення
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="mb-1">Ви дійсно хочете видалити документ:</p>
                <strong id="modalDocTitle" class="text-dark fs-5"></strong>
                <p class="text-muted mt-3 small mb-0">Ця дія незворотна. Файл буде назавжди видалено з сервера.</p>
            </div>
            <div class="modal-footer border-top-0 d-flex justify-content-between" style="background: var(--surface-soft);">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Скасувати</button>
                <form asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="modalDocId" value="" />
                    <button type="submit" class="btn btn-danger px-4"><i class="bi bi-trash me-1"></i> Видалити назавжди</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteModal')
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget
                var docId = button.getAttribute('data-doc-id')
                var docTitle = button.getAttribute('data-doc-title')
                deleteModal.querySelector('#modalDocId').value = docId
                deleteModal.querySelector('#modalDocTitle').textContent = docTitle
            })
        });
    </script>
}
