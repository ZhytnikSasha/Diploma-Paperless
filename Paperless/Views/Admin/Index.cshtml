@model IEnumerable<Paperless.Models.ViewModels.UserViewModel>

@{
    ViewData["Title"] = "Управління користувачами";
}

<div class="page-head">
    <div class="eyebrow text-danger">Адміністрування</div>
    <h1><i class="bi bi-people text-danger me-2"></i>@ViewData["Title"]</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card reveal mb-5">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ПІБ співробітника</th>
                        <th>Email / Логін</th>
                        <th>Посада</th>
                        <th>Поточні ролі</th>
                        <th class="text-center pe-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@user.FullName</td>
                            <td class="text-muted">@user.Email</td>
                            <td>@user.Position</td>
                            <td>
                                @foreach (var role in user.Roles.Split(", "))
                                {
                                    if (role == "Адміністратор")
                                    {
                                        <span class="badge bg-danger">@role</span>
                                    }
                                    else if (role == "Менеджер")
                                    {
                                        <span class="badge bg-warning">@role</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@role</span>
                                    }
                                }
                            </td>
                            <td class="text-center pe-4">
                                <a asp-action="ManageRoles" asp-route-userId="@user.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-shield-check me-1"></i> Змінити ролі
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
